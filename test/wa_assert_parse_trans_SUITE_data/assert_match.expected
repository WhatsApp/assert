-file("assert_match.erl", 1).
-module(assert_match).
-export([match/2]).
match(Pattern, Expr) ->
    erlang:error({assertMatch, [{value, Expr}]},
                 none,
                 begin
                     Pins = #{'Pattern' => Pattern},
                     wa_assert:error_info("Pattern", Pins)
                 end).
