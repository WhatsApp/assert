-file("assert_match.erl", 1).
-module(assert_match).
-export([match/2]).
match(Pattern, Expr) ->
    case Expr of
        Pattern -> ok;
        X__V ->
            erlang:error({assertMatch, [{value, X__V}]},
                         none,
                         wa_assert:error_info("Pattern",
                                              #{'Pattern' => Pattern}))
    end.
